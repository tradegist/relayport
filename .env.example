# DigitalOcean
DO_API_TOKEN=your_digitalocean_api_token

# Droplet IP address (you will get it after executing the deploy.sh script)
DROPLET_IP=your_droplet_ip_address

# IBKR Credentials
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
TRADING_MODE=paper

# VNC Access (for 2FA via browser)
VNC_SERVER_PASSWORD=your_vnc_password

# Webhook Configuration
TARGET_WEBHOOK_URL=https://example.com/webhook
WEBHOOK_SECRET=your_hmac_secret_key
# Optional: add a custom header to webhook requests
#WEBHOOK_HEADER_NAME=X-Custom-Header
#WEBHOOK_HEADER_VALUE=your_header_value

# Flex Web Service (get from Client Portal → Reporting → Flex Queries)
IBKR_FLEX_TOKEN=your_flex_web_service_token
IBKR_FLEX_QUERY_ID=your_trade_confirmation_query_id

# Poll interval in seconds (default: 600 = 10 minutes)
POLL_INTERVAL_SECONDS=600

# Timezone (tz database format)
TIME_ZONE=America/New_York

# IB Gateway memory allocation in MB (default: 768)
# Higher values allow faster data retrieval. Recommended: 4096 for API use.
# Droplet size is auto-selected based on this value (max: 10240).
JAVA_HEAP_SIZE=768

# Domains (DNS A records must point to droplet IP)
VNC_DOMAIN=vnc.example.com
TRADE_DOMAIN=trade.example.com

# API token for securing the /ibkr/* endpoints (generate with: openssl rand -hex 32)
API_TOKEN=your_api_token

# CLI default target environment: "prod" (HTTPS via TRADE_DOMAIN) or "local" (localhost:15000)
# Override per-command with: make order ENV=local
DEFAULT_CLI_RELAY_ENV=prod

# --- Second Poller (optional) ---
# Uncomment and fill these to run a second independent poller.
# Each has its own Flex query, webhook destination, and poll interval.
# The second poller is triggered via: make poll2 or POST /ibkr/poller/2/run
#IBKR_FLEX_TOKEN_2=your_second_flex_token
#IBKR_FLEX_QUERY_ID_2=your_second_query_id
#TARGET_WEBHOOK_URL_2=https://example.com/webhook2
#WEBHOOK_SECRET_2=your_second_hmac_secret
#WEBHOOK_HEADER_NAME_2=X-Custom-Header
#WEBHOOK_HEADER_VALUE_2=your_header_value
#POLL_INTERVAL_SECONDS_2=600
