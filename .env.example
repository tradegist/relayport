# ── Deployment ────────────────────────────────────────────────────────
# Mode (REQUIRED): "standalone" or "shared"
# standalone = own droplet via Terraform (requires DO_API_TOKEN)
# shared     = deploy to an existing droplet (requires DROPLET_IP + SSH_KEY)
DEPLOY_MODE=standalone

# DigitalOcean API token (standalone mode only — can be removed after first deploy)
DO_API_TOKEN=your_digitalocean_api_token

# Droplet IP address (from Terraform output, or provided by host in shared mode)
DROPLET_IP=your_droplet_ip_address

# SSH key for droplet access (shared mode only).
# In standalone mode, Terraform generates and saves the key automatically
# to ~/.ssh/ibkr-relay — you never need to set this.
# Only set this in shared mode, using the key provided by the droplet owner.
#SSH_KEY=~/.ssh/shared-droplet

# Override droplet size slug (standalone mode only).
# Poller-only needs minimal resources: s-1vcpu-512mb ($4/mo) or s-1vcpu-1gb ($6/mo).
#DROPLET_SIZE=s-1vcpu-512mb

# Docker network name for cross-project communication on the same droplet.
# Set to the same value across all projects that need to reach each other's containers.
# Leave unset for isolated standalone deployment.
# SHARED_NETWORK=relay-net

# ── Domains & API ────────────────────────────────────────────────────
# DNS A record must point to droplet IP.
SITE_DOMAIN=trade.example.com

# Bearer token for /ibkr/* endpoints (generate with: openssl rand -hex 32)
API_TOKEN=your_api_token

# ── Notifications ────────────────────────────────────────────────────
# Active backends (comma-separated, e.g. "webhook"). Empty = dry-run.
NOTIFIERS=webhook

# Webhook settings (required when NOTIFIERS includes "webhook")
TARGET_WEBHOOK_URL=https://example.com/webhook
WEBHOOK_SECRET=your_hmac_secret_key
# Optional: add a custom header to webhook requests
#WEBHOOK_HEADER_NAME=X-Custom-Header
#WEBHOOK_HEADER_VALUE=your_header_value

# Debug webhook inbox — when set, overrides TARGET_WEBHOOK_URL to route
# all webhooks to an in-memory inbox at /debug/webhook/<path>.
# View captured payloads via GET, clear via DELETE.
# The ibkr-debug container starts automatically when this is set.
#DEBUG_WEBHOOK_PATH=abcdef
#MAX_DEBUG_WEBHOOK_PAYLOADS=100
#DEBUG_LOG_LEVEL=INFO

# ── Poller ────────────────────────────────────────────────────────────
# Set to "false" to disable the poller container entirely.
#POLLER_ENABLED=false

# Flex Web Service (get from Client Portal → Reporting → Flex Queries)
IBKR_FLEX_TOKEN=your_flex_web_service_token
IBKR_FLEX_QUERY_ID=your_trade_confirmation_query_id
POLL_INTERVAL_SECONDS=600

# ── Second Poller (optional) ─────────────────────────────────────────
# Uncomment to run a second independent poller with its own Flex query,
# webhook destination, and poll interval.
# Only IBKR_FLEX_QUERY_ID_2 is required — IBKR_FLEX_TOKEN_2 is optional.
# When omitted, the primary IBKR_FLEX_TOKEN is used (useful when both
# queries share the same Flex Web Service token).
# Triggered via: make poll2 or POST /ibkr/poller/2/run
#IBKR_FLEX_QUERY_ID_2=your_second_query_id
#IBKR_FLEX_TOKEN_2=your_second_flex_token
#NOTIFIERS_2=webhook
#TARGET_WEBHOOK_URL_2=https://example.com/webhook2
#WEBHOOK_SECRET_2=your_second_hmac_secret
#WEBHOOK_HEADER_NAME_2=X-Custom-Header
#WEBHOOK_HEADER_VALUE_2=your_header_value
#POLL_INTERVAL_SECONDS_2=600

# ── Listener (real-time trade events via IB Gateway) ─────────────────
# Set to any non-empty value to enable real-time trade event webhooks
# from the remote-client service. Requires at least one notifier backend
# configured via NOTIFIERS with its corresponding env vars.
# NOTE: Requires REMOTE_CLIENT_ENABLED=true (the default). Has no effect
# when the remote-client service is disabled.
#LISTENER_ENABLED=true

# Enable execDetailsEvent webhooks (preliminary fill without commission data).
# Default: disabled. When disabled, only commissionReportEvent fires webhooks
# (confirmed fills with commission). Enable if you need sub-second latency
# and can tolerate the extra webhook volume (2x per fill).
#LISTENER_EXEC_EVENTS_ENABLED=false

# Milliseconds to debounce incoming real-time fills before firing webhooks.
# Useful for grouping rapidly executing partial fills into a single webhook
# request (which gets deduped against previous executions). Default: 0 (disabled).
#LISTENER_EVENT_DEBOUNCE_TIME=2000

# ── General ──────────────────────────────────────────────────────────
TIME_ZONE=America/New_York

# CLI default target environment: "prod" (HTTPS via SITE_DOMAIN) or "local" (localhost:15001)
# Override per-command with: make poll ENV=local
DEFAULT_CLI_RELAY_ENV=prod
