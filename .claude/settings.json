{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.droplet)",
      "Read(.env.relays)",
      "Read(.env.test)",
      "Bash(cat .env)",
      "Bash(cat .env.droplet)",
      "Bash(cat .env.relays)",
