{
  "$defs": {
    "BuySell": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "BuySell",
      "type": "string"
    },
    "Trade": {
      "additionalProperties": false,
      "description": "Aggregated trade (one or more fills for the same order).",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "enum": [
                "market",
                "limit",
                "stop",
                "stop_limit",
                "trailing_stop"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "fillCount": {
          "type": "integer"
        },
        "execIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "enum": [
            "flex",
            "execDetailsEvent",
            "commissionReportEvent"
          ],
          "type": "string"
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "orderId",
        "symbol",
        "side",
        "price",
        "volume",
        "cost",
        "fee",
        "fillCount",
        "execIds",
        "timestamp",
        "source",
        "raw"
      ],
      "title": "Trade",
      "type": "object"
    },
    "WebhookPayload": {
      "additionalProperties": false,
      "description": "Payload sent to the target webhook URL.",
      "properties": {
        "trades": {
          "items": {
            "$ref": "#/$defs/Trade"
          },
          "type": "array"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "trades",
        "errors"
      ],
      "title": "WebhookPayload",
      "type": "object"
    },
    "Fill": {
      "additionalProperties": false,
      "description": "Individual execution from IBKR (CommonFill spec).",
      "properties": {
        "execId": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "enum": [
                "market",
                "limit",
                "stop",
                "stop_limit",
                "trailing_stop"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "enum": [
            "flex",
            "execDetailsEvent",
            "commissionReportEvent"
          ],
          "type": "string"
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "execId",
        "orderId",
        "symbol",
        "side",
        "price",
        "volume",
        "cost",
        "fee",
        "timestamp",
        "source",
        "raw"
      ],
      "title": "Fill",
      "type": "object"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/WebhookPayload"
    },
    {
      "$ref": "#/$defs/Trade"
    },
    {
      "$ref": "#/$defs/Fill"
    }
  ]
}
