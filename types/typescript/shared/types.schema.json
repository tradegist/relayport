{
  "$defs": {
    "BuySell": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "BuySell",
      "type": "string"
    },
    "Trade": {
      "additionalProperties": false,
      "description": "Aggregated trade (one or more fills for the same order).",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "$ref": "#/$defs/AssetClass"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrderType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "fillCount": {
          "type": "integer"
        },
        "execIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "price",
        "volume",
        "cost",
        "fee",
        "fillCount",
        "execIds",
        "timestamp",
        "source",
        "raw"
      ],
      "title": "Trade",
      "type": "object"
    },
    "Fill": {
      "additionalProperties": false,
      "description": "Individual execution from a broker (CommonFill spec).",
      "properties": {
        "execId": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "$ref": "#/$defs/AssetClass"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrderType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "execId",
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "price",
        "volume",
        "cost",
        "fee",
        "timestamp",
        "source",
        "raw"
      ],
      "title": "Fill",
      "type": "object"
    },
    "AssetClass": {
      "enum": [
        "crypto",
        "equity",
        "forex",
        "future",
        "option",
        "other"
      ],
      "type": "string"
    },
    "OrderType": {
      "enum": [
        "limit",
        "market",
        "stop",
        "stop_limit",
        "trailing_stop"
      ],
      "type": "string"
    },
    "RelayName": {
      "enum": [
        "ibkr",
        "kraken"
      ],
      "type": "string"
    },
    "Source": {
      "enum": [
        "commissionReportEvent",
        "execDetailsEvent",
        "flex",
        "rest_poll",
        "ws_execution"
      ],
      "type": "string"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/Trade"
    },
    {
      "$ref": "#/$defs/Fill"
    }
  ]
}
