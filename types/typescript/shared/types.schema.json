{
  "$defs": {
    "BuySell": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "BuySell",
      "type": "string"
    },
    "OptionContract": {
      "additionalProperties": false,
      "description": "Option-specific contract metadata.\n\nPopulated only on fills/trades whose ``assetClass == \"option\"``. Future\nderivatives (futures, FOPs, warrants) will get their own sibling\ncontract objects rather than reusing this one \u2014 see\n``docs/migrate-trade-models-to-discriminated-union.md`` for the planned\ndiscriminated-union evolution.",
      "properties": {
        "rootSymbol": {
          "type": "string"
        },
        "strike": {
          "type": "number"
        },
        "expiryDate": {
          "type": "string"
        },
        "type": {
          "enum": [
            "call",
            "put"
          ],
          "type": "string"
        }
      },
      "required": [
        "rootSymbol",
        "strike",
        "expiryDate",
        "type"
      ],
      "title": "OptionContract",
      "type": "object"
    },
    "Trade": {
      "additionalProperties": false,
      "description": "Aggregated trade (one or more fills for the same order).",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "$ref": "#/$defs/AssetClass"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrderType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "fillCount": {
          "type": "integer"
        },
        "execIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "option": {
          "anyOf": [
            {
              "$ref": "#/$defs/OptionContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRateBase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRateSource": {
          "anyOf": [
            {
              "$ref": "#/$defs/FxRateSource"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "orderType",
        "price",
        "volume",
        "cost",
        "fee",
        "fillCount",
        "execIds",
        "timestamp",
        "source",
        "currency",
        "option",
        "fxRate",
        "fxRateBase",
        "fxRateSource",
        "raw"
      ],
      "title": "Trade",
      "type": "object"
    },
    "Fill": {
      "additionalProperties": false,
      "description": "Individual execution from a broker (CommonFill spec).",
      "properties": {
        "execId": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "$ref": "#/$defs/AssetClass"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrderType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "option": {
          "anyOf": [
            {
              "$ref": "#/$defs/OptionContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "execId",
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "orderType",
        "price",
        "volume",
        "cost",
        "fee",
        "timestamp",
        "source",
        "currency",
        "option",
        "raw"
      ],
      "title": "Fill",
      "type": "object"
    },
    "AssetClass": {
      "enum": [
        "crypto",
        "equity",
        "forex",
        "future",
        "option",
        "other"
      ],
      "type": "string"
    },
    "FxRateSource": {
      "enum": [
        "historical",
        "latest"
      ],
      "type": "string"
    },
    "OrderType": {
      "enum": [
        "limit",
        "market",
        "stop",
        "stop_limit",
        "trailing_stop"
      ],
      "type": "string"
    },
    "RelayName": {
      "enum": [
        "ibkr",
        "kraken"
      ],
      "type": "string"
    },
    "Source": {
      "enum": [
        "commissionReportEvent",
        "execDetailsEvent",
        "flex",
        "rest_poll",
        "ws_execution"
      ],
      "type": "string"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/Trade"
    },
    {
      "$ref": "#/$defs/Fill"
    }
  ]
}
