{
  "$defs": {
    "BuySell": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "BuySell",
      "type": "string"
    },
    "OptionContract": {
      "additionalProperties": false,
      "description": "Option-specific contract metadata.\n\nPopulated only on fills/trades whose ``assetClass == \"option\"``. Future\nderivatives (futures, FOPs, warrants) will get their own sibling\ncontract objects rather than reusing this one \u2014 see\n``docs/migrate-trade-models-to-discriminated-union.md`` for the planned\ndiscriminated-union evolution.",
      "properties": {
        "rootSymbol": {
          "type": "string"
        },
        "strike": {
          "type": "number"
        },
        "expiryDate": {
          "type": "string"
        },
        "type": {
          "enum": [
            "call",
            "put"
          ],
          "type": "string"
        }
      },
      "required": [
        "rootSymbol",
        "strike",
        "expiryDate",
        "type"
      ],
      "title": "OptionContract",
      "type": "object"
    },
    "Trade": {
      "additionalProperties": false,
      "description": "Aggregated trade (one or more fills for the same order).",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "enum": [
            "equity",
            "option",
            "crypto",
            "future",
            "forex",
            "other"
          ],
          "type": "string"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "enum": [
                "market",
                "limit",
                "stop",
                "stop_limit",
                "trailing_stop"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "fillCount": {
          "type": "integer"
        },
        "execIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "enum": [
            "flex",
            "execDetailsEvent",
            "commissionReportEvent",
            "rest_poll",
            "ws_execution"
          ],
          "type": "string"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "option": {
          "anyOf": [
            {
              "$ref": "#/$defs/OptionContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRateBase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fxRateSource": {
          "anyOf": [
            {
              "enum": [
                "historical",
                "latest"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "orderType",
        "price",
        "volume",
        "cost",
        "fee",
        "fillCount",
        "execIds",
        "timestamp",
        "source",
        "currency",
        "option",
        "fxRate",
        "fxRateBase",
        "fxRateSource",
        "raw"
      ],
      "title": "Trade",
      "type": "object"
    },
    "WebhookPayloadTrades": {
      "additionalProperties": false,
      "description": "Webhook payload for trade execution events.",
      "properties": {
        "relay": {
          "$ref": "#/$defs/RelayName"
        },
        "type": {
          "const": "trades",
          "default": "trades",
          "type": "string"
        },
        "data": {
          "items": {
            "$ref": "#/$defs/Trade"
          },
          "type": "array"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "relay",
        "data",
        "errors",
        "type"
      ],
      "title": "WebhookPayloadTrades",
      "type": "object"
    },
    "RunPollResponse": {
      "additionalProperties": false,
      "properties": {
        "trades": {
          "items": {
            "$ref": "#/$defs/Trade"
          },
          "type": "array"
        }
      },
      "required": [
        "trades"
      ],
      "title": "RunPollResponse",
      "type": "object"
    },
    "HealthResponse": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "title": "HealthResponse",
      "type": "object"
    },
    "RelayName": {
      "enum": [
        "ibkr",
        "kraken"
      ],
      "type": "string"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/WebhookPayloadTrades"
    },
    {
      "$ref": "#/$defs/RunPollResponse"
    },
    {
      "$ref": "#/$defs/HealthResponse"
    }
  ]
}
