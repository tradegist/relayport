# E2E test environment — paper account only.
# Copy to .env.test and fill in real values.

# !! Provide your IBKR paper account — real orders will be placed in paper mode.
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password

# API token for test endpoints (hardcoded in docker-compose.test.yml)
API_TOKEN=test-token

# --- Listener E2E (optional — opt-in only) ---
# Uncomment and fill these values only when running listener E2E tests
# against a local ibkr_bridge stack.
# Start the bridge first: cd ../ibkr_bridge && make local-up
# BRIDGE_WS_URL is used by the poller container (host.docker.internal = Docker host).
# BRIDGE_API_BASE_URL is used by the pytest host-side test.
# Set LISTENER_ENABLED=true and uncomment the BRIDGE_* vars below to enable.
LISTENER_ENABLED=false
# BRIDGE_WS_URL=ws://host.docker.internal:15101/ibkr/ws/events
# BRIDGE_API_BASE_URL=http://localhost:15101
# BRIDGE_API_TOKEN=your_bridge_api_token

# --- Unused by tests (dummy values satisfy docker-compose.yml parsing) ---
VNC_DOMAIN=unused
SITE_DOMAIN=unused
VNC_SERVER_PASSWORD=unused
IBKR_FLEX_TOKEN=unused
IBKR_FLEX_QUERY_ID=0
IBKR_FLEX_QUERY_ID_2=0
