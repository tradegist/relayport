# Exclude everything, then allow only what the poller Dockerfile needs.

*

!services/poller/**
services/poller/tests/
services/poller/Dockerfile
services/poller/**/test_*.py
services/poller/**/__pycache__/

!services/remote-client/**
services/remote-client/tests/
services/remote-client/Dockerfile
services/remote-client/**/test_*.py
services/remote-client/**/__pycache__/

!services/notifier/**
services/notifier/**/test_*.py
services/notifier/**/__pycache__/

!services/dedup/**
services/dedup/**/test_*.py
services/dedup/**/__pycache__/

!services/shared/**
services/shared/**/test_*.py
services/shared/**/__pycache__/
