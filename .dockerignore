# Exclude everything, then allow only what the Dockerfiles need.

*

!services/relay_core/**
services/relay_core/Dockerfile
services/relay_core/**/test_*.py
services/relay_core/**/__pycache__/

!services/relays/**
services/relays/**/test_*.py
services/relays/**/__pycache__/

!services/shared/**
services/shared/**/test_*.py
services/shared/**/__pycache__/

!services/debug/**
services/debug/Dockerfile
services/debug/**/test_*.py
services/debug/**/__pycache__/
