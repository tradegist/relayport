# ── Relay-specific env vars ───────────────────────────────────────────
# All vars here are prefixed with the relay name (e.g. IBKR_*).
# They are injected into the relays container via env_file in docker-compose.yml.
# Adding a new relay? Just add its prefixed vars below — no compose changes needed.

# ── IBKR Relay ────────────────────────────────────────────────────────
# Flex Web Service (get from Client Portal → Reporting → Flex Queries)
IBKR_FLEX_TOKEN=your_flex_web_service_token
IBKR_FLEX_QUERY_ID=your_trade_confirmation_query_id

# ── IBKR Flex Lookback (optional) ─────────────────────────────────────
# Override the saved Flex query's Period with "last N calendar days"
# via the documented &p= URL param. Values: 1-365 (IBKR-enforced cap).
# Useful when the IBKR UI's "Number of Days" field doesn't persist your
# saved value, or when you want the relay to control the window without
# reconfiguring the query at IBKR.
# Omit (default) to use whatever Period the saved query has.
#IBKR_FLEX_LOOKBACK_DAYS=40

# ── IBKR Second Account (optional) ───────────────────────────────────
# Uncomment to poll a second Flex query within the same relay container.
# Only IBKR_FLEX_QUERY_ID_2 is required — IBKR_FLEX_TOKEN_2 is optional.
# When omitted, the primary IBKR_FLEX_TOKEN is used (useful when both
# queries share the same Flex Web Service token).
# Triggered via: make poll RELAY=ibkr IDX=2 or POST /relays/ibkr/poll/2
#IBKR_FLEX_QUERY_ID_2=your_second_query_id
#IBKR_FLEX_TOKEN_2=your_second_flex_token

# ── IBKR Account Timezone ────────────────────────────────────────────
# IBKR reports every trade timestamp (Flex XML + bridge WS) in the
# account's base timezone with NO tz label. Set this to a valid IANA
# timezone so the engine can convert them to UTC before storing.
# Omit or leave blank to treat timestamps as UTC (correct only if your
# IBKR account's base tz is UTC). Invalid values cause boot-time exit.
# Examples: America/New_York, Europe/Zurich, Asia/Tokyo, UTC
#IBKR_ACCOUNT_TIMEZONE=America/New_York

# ── IBKR Listener (real-time trade events from ibkr_bridge) ──────────
# Connects to ibkr_bridge's WebSocket endpoint for near-instant trade
# event webhooks, instead of waiting for Flex polling (10min+ delay).
# Requires at least one notifier backend configured via NOTIFIERS.

# WebSocket URL for the bridge endpoint.
# Same droplet (shared network): ws://bridge:5000/ibkr/ws/events
# Cross-droplet: wss://trade.example.com/ibkr/ws/events
#IBKR_BRIDGE_WS_URL=ws://bridge:5000/ibkr/ws/events

# Bearer token for authenticating to the bridge WS endpoint
# (same value as API_TOKEN on the bridge side).
#IBKR_BRIDGE_API_TOKEN=your_bridge_api_token

# Enable execDetailsEvent webhooks (preliminary fill without commission data).
# Default: disabled. When disabled, only commissionReportEvent fires webhooks
# (confirmed fills with commission). Enable if you need sub-second latency
# and can tolerate the extra webhook volume (2x per fill).
#IBKR_LISTENER_EXEC_EVENTS_ENABLED=false

# IBKR-specific overrides for generic vars (optional).
# When set, these override the generic NOTIFIERS/TARGET_WEBHOOK_URL/etc.
# for the IBKR relay only. Useful when running multiple relays with
# different webhook destinations.
#IBKR_NOTIFIERS=webhook
#IBKR_TARGET_WEBHOOK_URL=https://example.com/ibkr-webhook
#IBKR_WEBHOOK_SECRET=your_ibkr_hmac_secret
#IBKR_WEBHOOK_HEADER_NAME=X-Custom-Header
#IBKR_WEBHOOK_HEADER_VALUE=your_header_value
#IBKR_TARGET_WEBHOOK_URL_2=https://example.com/ibkr-webhook2
#IBKR_WEBHOOK_SECRET_2=your_second_ibkr_hmac_secret
#IBKR_WEBHOOK_HEADER_NAME_2=X-Custom-Header
#IBKR_WEBHOOK_HEADER_VALUE_2=your_header_value
#IBKR_POLL_INTERVAL=600
#IBKR_POLLER_ENABLED=true
#IBKR_LISTENER_ENABLED=true
#IBKR_LISTENER_DEBOUNCE_MS=2000
#IBKR_NOTIFY_RETRIES=0
#IBKR_NOTIFY_RETRY_DELAY_MS=1000

# ── Kraken Relay ──────────────────────────────────────────────────────
# API credentials (get from kraken.com → Settings → API)
# Required for polling: Query Funds, Query Open/Closed Orders & Trades.  
# Access WebSockets API is only required when enabling the Kraken listener  
# (KRAKEN_LISTENER_ENABLED=true); it is optional for polling-only setups. 
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_base64_encoded_api_secret

# Poller: fetches TradesHistory via REST at the configured interval.
# Default: 600s (10 min). Override with KRAKEN_POLL_INTERVAL.
#KRAKEN_POLL_INTERVAL=600

# How far back each poll looks for trades (in days). Must be >= 1.
# Default: 30 days. Increase if you need more history (e.g. 365).
# The dedup DB prevents duplicate webhooks for already-processed fills.
#KRAKEN_LOOKBACK_DAYS=30

# Listener: real-time fills via Kraken WS v2 executions channel.
# Connects to wss://ws-auth.kraken.com/v2 — no external bridge needed.
# Default: disabled. Set to true to enable.
#KRAKEN_LISTENER_ENABLED=false

# Debounce: buffer incoming WS fills for N ms before dispatching a webhook.
# Useful when a single order generates rapid partial fills (0 = disabled).
#KRAKEN_LISTENER_DEBOUNCE_MS=0

# Kraken-specific overrides for generic vars (optional).
# When set, these override NOTIFIERS/TARGET_WEBHOOK_URL/etc. for the
# Kraken relay only. Useful when running alongside IBKR with different
# webhook destinations.
#KRAKEN_NOTIFIERS=webhook
#KRAKEN_TARGET_WEBHOOK_URL=https://example.com/kraken-webhook
#KRAKEN_WEBHOOK_SECRET=your_kraken_hmac_secret
#KRAKEN_WEBHOOK_HEADER_NAME=X-Custom-Header
#KRAKEN_WEBHOOK_HEADER_VALUE=your_header_value
#KRAKEN_POLLER_ENABLED=true
#KRAKEN_NOTIFY_RETRIES=0
#KRAKEN_NOTIFY_RETRY_DELAY_MS=1000
